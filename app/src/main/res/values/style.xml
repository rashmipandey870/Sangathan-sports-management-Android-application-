<?xml version="1.0" encoding="utf-8"?>
<resources>

<style name="ChipDark">
    <item name="android:background">#1C2A44</item>
    <item name="android:textColor">#9EC8FF</item>
    <item name="android:paddingHorizontal">14dp</item>
    <item name="android:paddingVertical">6dp</item>
    <item name="android:layout_marginEnd">8dp</item>

    </style>
    <style
    name="BtnBlueSmall">
        <item name="android:background">@drawable/gradient_btn_blue</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">8dp</item>
</style>
    <style name="BtnGreenSmall">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_weight">1</item>

        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>

        <item name="android:background">@drawable/btn_green_small_selector</item>

        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>

        <!-- IMPORTANT: remove default Material tint -->
        <item name="backgroundTint">@null</item>
    </style>
</resources>