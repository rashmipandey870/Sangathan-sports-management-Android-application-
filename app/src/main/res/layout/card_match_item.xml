<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULED MATCH"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/chip_text"
                android:background="@color/chip_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_alignParentStart="true" />

            <TextView
                android:id="@+id/tv_match_venue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Venue: Main Ground"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Teams VS Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_match_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CSE CRICKET vs BBA CRICKET"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_centerHorizontal="true"
                android:gravity="center" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_color"
            android:layout_marginBottom="10dp" />

        <!-- Date and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_match_datetime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monday, Oct 12 • 10:30 AM"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>