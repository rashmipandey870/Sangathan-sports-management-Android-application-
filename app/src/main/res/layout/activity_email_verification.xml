<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Back Button Area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true" />
        </RelativeLayout>

        <!-- Form Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_user"
                android:layout_marginTop="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Verification PIN"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A 6-digit PIN has been sent to your registered email."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/et_verification_pin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter 6-digit PIN"
                android:inputType="number"
                android:maxLength="6"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:textColor="@color/text_main"
                android:textColorHint="#8A9CB4"
                android:background="@drawable/bg_input_dark"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_verify_pin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:cornerRadius="12dp"
                android:backgroundTint="#1E88E5"
                android:text="Verify PIN"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Didn't receive the PIN?"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tv_resend_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resend PIN"
                android:textColor="#1E88E5"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
