<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#131C2D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Student Name -->
            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tv_student_status"/>

            <!-- Status Tag -->
            <TextView
                android:id="@+id/tv_student_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECTED"
                android:textColor="#388E3C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Department info -->
        <TextView
            android:id="@+id/tv_student_department"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Department"
            android:textColor="#8A9CB4"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <!-- Team & Gender details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_student_team"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#1A1E88E5"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginRight="8dp"/>

            <TextView
                android:id="@+id/tv_student_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textColor="#9333EA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#1A9333EA"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>