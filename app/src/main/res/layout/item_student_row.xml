<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:id="@+id/tv_student_name"
            android:text="Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#0F172A"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:id="@+id/tv_student_department"
            android:text="Department"
            android:textColor="#475569"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:id="@+id/tv_student_team"
            android:text="Team"
            android:textColor="#2563EB"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:id="@+id/tv_student_gender"
            android:text="Gender"
            android:textColor="#9333EA"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:id="@+id/tv_student_status"
            android:text="Status"
            android:textColor="#16A34A"
            android:textStyle="bold"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_select"
                android:text="Select"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#16A34A"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btn_reject"
                android:text="Reject"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:backgroundTint="#DC2626"
                android:textColor="@android:color/white"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>