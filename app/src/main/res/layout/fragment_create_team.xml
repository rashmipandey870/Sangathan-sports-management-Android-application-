<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Team"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SPORT -->
                <TextView
                    android:id="@+id/tv_sport_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Sport"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <Spinner
                    android:id="@+id/sp_sport"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_dark"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:id="@+id/tv_fixed_sport"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_dark"
                    android:padding="14dp"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <!-- TEAM NAME -->
                <EditText
                    android:id="@+id/et_team_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Team Name (e.g. BBA BOYS CRICKET)"
                    android:background="@drawable/bg_input_dark"
                    android:padding="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- CAPTAIN NAME -->
                <EditText
                    android:id="@+id/et_captain_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Captain Name"
                    android:background="@drawable/bg_input_dark"
                    android:padding="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- ENROLLMENT -->
                <EditText
                    android:id="@+id/et_captain_enrollment"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Captain Enrollment No."
                    android:background="@drawable/bg_input_dark"
                    android:padding="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- DEPARTMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Department"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <Spinner
                    android:id="@+id/sp_captain_department"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_dark"
                    android:layout_marginBottom="12dp"/>

                <!-- GENDER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Gender"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <Spinner
                    android:id="@+id/sp_gender"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_dark"
                    android:layout_marginBottom="16dp"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/btn_create_team"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Create Team"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="@drawable/gradient_btn_blue"
                    app:backgroundTint="@null"/>

                <!-- PIN OUTPUT -->
                <TextView
                    android:id="@+id/tv_generated_pin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_marginTop="14dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>