<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Team"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="6dp"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create team and generate captain PIN"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- SPORT -->
                <Spinner
                    android:id="@+id/sp_sport"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_light"
                    android:layout_marginBottom="12dp"/>

                <!-- TEAM NAME -->
                <EditText
                    android:id="@+id/et_team_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Team Name (e.g. BBA BOYS CRICKET)"
                    android:background="@drawable/bg_input_light"
                    android:padding="14dp"/>

                <!-- CAPTAIN NAME -->
                <EditText
                    android:id="@+id/et_captain_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Captain Name"
                    android:background="@drawable/bg_input_light"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- ENROLLMENT -->
                <EditText
                    android:id="@+id/et_captain_enrollment"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Captain Enrollment No."
                    android:background="@drawable/bg_input_light"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- DEPARTMENT -->
                <EditText
                    android:id="@+id/et_captain_department"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Department (e.g. BBA, CSE)"
                    android:background="@drawable/bg_input_light"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- GENDER -->
                <Spinner
                    android:id="@+id/sp_gender"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input_light"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/btn_create_team"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Create Team"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:layout_marginTop="18dp"/>

                <!-- PIN OUTPUT -->
                <TextView
                    android:id="@+id/tv_generated_pin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_marginTop="14dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>