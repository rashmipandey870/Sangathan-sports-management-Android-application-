<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Team Name -->
            <TextView
                android:id="@+id/tv_team_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CSE CRICKET BOYS"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tv_team_pin"/>

            <!-- PIN -->
            <TextView
                android:id="@+id/tv_team_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PIN: 1234"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Captain Name -->
        <TextView
            android:id="@+id/tv_team_captain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Captain: John Doe"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <!-- Details Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Sport Badge -->
            <TextView
                android:id="@+id/tv_team_sport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CRICKET"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#1A1E88E5"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginRight="8dp"/>

            <!-- Gender Badge -->
            <TextView
                android:id="@+id/tv_team_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOYS"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#1A4CAF50"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>