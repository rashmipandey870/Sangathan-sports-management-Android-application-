<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ================= PROFILE HEADER ================= -->
        <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- SETTINGS BUTTON -->
                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings"
                    app:tint="#B5C7FF" />

                <!-- PROFILE CONTENT -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/profile_image"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_user"
                        android:background="@drawable/circle_blue_bg"
                        android:padding="16dp" />

                    <TextView
                        android:id="@+id/profile_name"
                        android:textColor="@color/text_main"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/profile_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= USER INFO ================= -->
        <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/profile_email"
                    android:textColor="@color/text_main"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email: —"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profile_phone"
                    android:textColor="@color/text_main"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone: —"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profile_batch"
                    android:textColor="@color/text_main"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch: —"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ================= EMAIL VERIFICATION ================= -->
        <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/bg_card"
            android:id="@+id/card_email_verification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:text="Email Verification"
                    android:textColor="@color/text_main"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_verification_status"
                    android:text="Your email is not verified"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textColor="#D32F2F"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_verify_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verify Email"
                    android:textAllCaps="false"
                    android:backgroundTint="#1E88E5"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ================= STATS ================= -->
        <LinearLayout
            android:id="@+id/stats_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <include
                layout="@layout/card_profile_stat"
                android:id="@+id/card_sports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                layout="@layout/card_profile_stat"
                android:id="@+id/card_events"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                layout="@layout/card_profile_stat"
                android:id="@+id/card_achievements"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- ================= SPORTS REGISTRATION ================= -->
        <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sports Registrations"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_trophy" />

                <TextView
                    android:id="@+id/tv_no_registration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No sports registered yet"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btn_register_sports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register for Sports"
                    android:textAllCaps="false"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/primary_blue"
                    android:textColor="@color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= ACHIEVEMENTS ================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Achievements"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />


        <include
            android:id="@+id/achievement_1"
            layout="@layout/card_achievement_item" />

        <include
            android:id="@+id/achievement_2"
            layout="@layout/card_achievement_item" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
