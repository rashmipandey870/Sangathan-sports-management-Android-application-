<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0B1220">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Your Role"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_student"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Student"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_captain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Captain"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_coordinator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sports Coordinator"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_head_admin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Head Admin"/>
</LinearLayout>