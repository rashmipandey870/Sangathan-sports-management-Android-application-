<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Left accent color bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="50dp"
            android:background="@color/primary_blue"
            android:layout_marginEnd="12dp" />

        <!-- Initials Avatar Badge -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_blue_bg"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tv_student_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="JD" />
        </FrameLayout>

        <!-- Player Information -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_student_department"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Department"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_student_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECTED"
                android:textColor="#388E3C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#1A388E3C"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Edit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Edit"
            android:textSize="12sp"
            android:textColor="@color/chip_text"
            android:backgroundTint="@color/chip_bg"
            app:cornerRadius="8dp"
            android:paddingHorizontal="12dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
